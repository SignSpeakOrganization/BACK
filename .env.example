# Environment Configuration
APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=1

# Flask Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Camera Configuration (optional - defaults can be used)
CAMERA_DEVICE=0
CAMERA_WIDTH=960
CAMERA_HEIGHT=540

# MediaPipe Configuration (optional - defaults can be used)
MIN_DETECTION_CONFIDENCE=0.7
MIN_TRACKING_CONFIDENCE=0.5

# Model Paths (optional - defaults are already set in code)
# KEYPOINT_MODEL_PATH=model/keypoint_classifier/keypoint_classifier.tflite
# POINT_HISTORY_MODEL_PATH=model/point_history_classifier/point_history_classifier.tflite
